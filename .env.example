# Supabase (create free project, run sql/create_table.sql, grab these two)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# SerpAPI free tier: https://serpapi.com (100 searches/month)
SERPAPI_KEY=your-serpapi-key

# OpenRouter: https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-key
# Free model by default; swap without code changes. Free models are
# frequently rate-limited upstream - openai/gpt-oss-20b:free and
# nvidia/nemotron-3-super-120b-a12b:free were reliable at time of writing.
OPENROUTER_MODEL=openai/gpt-oss-20b:free

# Optional
JINA_API_KEY=
MAX_JOBS_PER_RUN=20
